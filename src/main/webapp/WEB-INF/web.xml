<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_1.xsd"
         version="6.1"
         metadata-complete="false">

    <display-name>HireFlow Job Portal</display-name>

    <!-- Listeners -->
    <listener>
        <listener-class>com.hireflow.util.AppInitListener</listener-class>
    </listener>
    <listener>
        <listener-class>com.hireflow.util.AppStartupListener</listener-class>
    </listener>

    <!-- Filters -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.hireflow.util.AuthFilter</filter-class>
    </filter>
    <filter>
        <filter-name>CsrfFilter</filter-name>
        <filter-class>com.hireflow.util.CsrfFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Servlets -->
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.HomeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>JobPostServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.JobPostServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>JobDetailServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.JobDetailServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>JobSearchServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.JobSearchServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>JobDeleteServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.JobDeleteServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>JobApproveServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.JobApproveServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ApplyServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.ApplyServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ApplyFormServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.ApplyFormServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SeekerDashServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.SeekerDashServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EmployerDashServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.EmployerDashServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.AdminServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UpdateStatusServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.UpdateStatusServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DBTestServlet</servlet-name>
        <servlet-class>com.hireflow.servlet.DBTestServlet</servlet-class>
    </servlet>

    <!-- Servlet Mappings -->
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>JobPostServlet</servlet-name>
        <url-pattern>/jobs/create</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>JobDetailServlet</servlet-name>
        <url-pattern>/jobs/detail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>JobSearchServlet</servlet-name>
        <url-pattern>/jobs</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>JobDeleteServlet</servlet-name>
        <url-pattern>/jobs/delete</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>JobApproveServlet</servlet-name>
        <url-pattern>/jobs/approve</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ApplyServlet</servlet-name>
        <url-pattern>/apply</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ApplyFormServlet</servlet-name>
        <url-pattern>/apply/form</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SeekerDashServlet</servlet-name>
        <url-pattern>/dashboard/seeker</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EmployerDashServlet</servlet-name>
        <url-pattern>/dashboard/employer</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/panel</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateStatusServlet</servlet-name>
        <url-pattern>/applications/status</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DBTestServlet</servlet-name>
        <url-pattern>/test-db</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>